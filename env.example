# Database - PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/lms_seribu_bulan?schema=public"

# JWT Secret (CHANGE THIS IN PRODUCTION - min 32 characters)
JWT_SECRET="seribu-bulan-lms-jwt-secret-key-2024-change-in-production"
JWT_EXPIRATION="7d"

# MinIO / S3 Object Storage
S3_ENDPOINT="localhost"
S3_PORT="9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="lms-uploads"
S3_USE_SSL="false"
S3_REGION="ap-southeast-1"

# Next.js
NEXT_PUBLIC_APP_NAME="LMS Seribu Bulan"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
